# Copia este archivo a ".env" y rellena los valores (nunca subas .env al repositorio).
# Referencia: config.ts, index.ts, middelware/mailer.ts

# --- Obligatorias para arrancar ---
# URI de MongoDB (ej. mongodb://127.0.0.1:27017/dragonrock)
BD_URL=mongodb://127.0.0.1:27017/dragonrock

# Secreto para firmar y verificar JWT (usa una cadena larga y aleatoria en producción)
JWT_KEY=cambiar-por-secreto-largo-y-aleatorio

# --- Servidor HTTP ---
NODE_ENV=development
PORT=3031
HOST=http://localhost

# Caducidad del token JWT (ej. 7d, 365d)
JWT_EXPIRES_IN=365d

# --- MongoDB ---
# true / false: verbosidad de consultas Mongoose (opcional)
MONGO_DEBUG=false

# --- Rutas estáticas ---
PUBLIC_ROUTE=/public
FILES_ROUTE=/files

# --- Negocio (usuarios / correos transaccionales) ---
# ID MongoDB de la empresa por defecto (plantillas de registro y recuperación de clave)
COMPANY_DEFAULT=

# ID MongoDB del usuario administrador (flujo de registro público con empresa nueva)
USER_ADMIN=

# --- Mailjet (usado en middelware/mailer.ts) ---
MJ_APIKEY_PUBLIC=
MJ_APIKEY_PRIVATE=

# --- SMTP / mailer (config.ts; por si se usa en otro flujo) ---
MAILER_HOST=
MAILER_PORT=
MAILER_USER=
MAILER_PASS=
# true, false o cadena según tu proveedor
MAILER_SECURE=false
