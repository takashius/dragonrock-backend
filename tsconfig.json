{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false
  },
  "include": [
    "index.ts",
    "config.ts",
    "db.ts",
    "swagger.ts",
    "composition/**/*.ts",
    "application/**/*.ts",
    "domain/**/*.ts",
    "infrastructure/**/*.ts",
    "presentation/**/*.ts",
    "network/**/*.ts",
    "components/**/*.ts",
    "middelware/**/*.ts",
    "documentation/**/*.ts",
    "types/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
